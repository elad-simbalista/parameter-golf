def _env(name: str, fallback: str) -> str:
    preset = PRESET_DEFAULTS.get(ARCH_PRESET)
    if preset is None:
        raise ValueError(
            f"Unsupported ARCH_PRESET={ARCH_PRESET!r}; expected one of "
            f"{sorted(PRESET_DEFAULTS)}"
        )
    return os.environ.get(name, preset.get(name, fallback))

